DATABASE_URL="postgresql://app:app@localhost:5432/boardgame_social?schema=public"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=1209600
JWT_REFRESH_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
PORT=3000
WEB_ORIGIN=http://localhost:5173
BOARDGAMES_CSV_PATH=prisma/games.csv
BOARDGAMES_ZIP_PATH=prisma/games.csv.zip
BOARDGAMES_TOP_LIMIT=40
BOARDGAMES_MIN_USER_RATINGS=500
# Optional: fail seed instead of fallback static list when dataset is unavailable
# BOARDGAMES_DATASET_STRICT=0
# Mock users + social data (enabled by default for local dev)
# SEED_MOCK_DATA=1
# SEED_USERS_COUNT=48
# SEED_USERS_PASSWORD=password123
# SEED_MEETUP_COUNT=36
# SEED_RNG_SEED=42
# SEED_PRUNE_GAMES=1

# --- S3 media storage ---
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=boardgame-media
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me